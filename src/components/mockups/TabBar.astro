---
interface Props {
  active: 'home' | 'lessons' | 'dictionary' | 'progress' | 'ranking' | 'settings';
}

const { active } = Astro.props;

const tabs = [
  { id: 'home', label: 'Hoy' },
  { id: 'lessons', label: 'Lecciones' },
  { id: 'dictionary', label: 'Diccionario' },
  { id: 'progress', label: 'Progreso' },
  { id: 'ranking', label: 'Ranking' },
  { id: 'settings', label: 'Ajustes' },
] as const;
---

<div class="absolute bottom-0 left-0 right-0 bg-white border-t border-[#e5e7eb]/80 flex justify-around items-end pt-1.5 pb-3 px-1 rounded-b-[2rem]">
  {tabs.map((tab) => {
    const isActive = tab.id === active;
    const color = isActive ? '#059669' : '#9ca3af';
    return (
      <div class="flex flex-col items-center gap-[2px] w-10">
        {/* Ionicon SVGs matching the actual app */}
        {tab.id === 'home' && !isActive && (
          <svg class="w-[20px] h-[20px]" viewBox="0 0 512 512" fill="none" stroke={color} stroke-width="32" stroke-linecap="round" stroke-linejoin="round"><path d="M80 212v236a16 16 0 0016 16h96V328a24 24 0 0124-24h80a24 24 0 0124 24v136h96a16 16 0 0016-16V212"/><path d="M480 256L266.89 52c-5-5.28-16.69-5.34-21.78 0L32 256"/></svg>
        )}
        {tab.id === 'home' && isActive && (
          <svg class="w-[20px] h-[20px]" viewBox="0 0 512 512" fill={color}><path d="M261.56 101.28a8 8 0 00-11.06 0L66 268.48A8 8 0 0060 274v189a8 8 0 008 8h136a8 8 0 008-8V355a8 8 0 018-8h72a8 8 0 018 8v108a8 8 0 008 8h136a8 8 0 008-8V274a8 8 0 00-2-5.52z"/><path d="M490.91 244.15l-74.8-71.56V64a8 8 0 00-8-8h-48a8 8 0 00-8 8v58.67l-68.28-65.35a32 32 0 00-44.1 0L21.09 244.15a8 8 0 00-.66 11.29L31.18 268a8 8 0 0011.34.66L256 81.81l213.48 186.85a8 8 0 0011.34-.66l10.75-12.56a8 8 0 00-.66-11.29z"/></svg>
        )}
        {tab.id === 'lessons' && !isActive && (
          <svg class="w-[20px] h-[20px]" viewBox="0 0 512 512" fill="none" stroke={color} stroke-width="32" stroke-linecap="round" stroke-linejoin="round"><path d="M256 160c16-63.16 76.43-95.41 208-96a15.94 15.94 0 0116 16v288a16 16 0 01-16 16c-128 0-177.45 25.81-208 64-30.37-38-80-64-208-64-9.88 0-16-8.05-16-17.93V80a15.94 15.94 0 0116-16c131.57.59 192 32.84 208 96z"/><path d="M256 160v288"/></svg>
        )}
        {tab.id === 'lessons' && isActive && (
          <svg class="w-[20px] h-[20px]" viewBox="0 0 512 512" fill={color}><path d="M464 48c-67.61.29-117.87 9.6-154.24 25.69-27.14 12-37.76 21.08-37.76 51.84V448c41.57-37.5 78.46-48 224-48V48zM48 48c67.61.29 117.87 9.6 154.24 25.69 27.14 12 37.76 21.08 37.76 51.84V448c-41.57-37.5-78.46-48-224-48V48z"/></svg>
        )}
        {tab.id === 'dictionary' && !isActive && (
          <svg class="w-[20px] h-[20px]" viewBox="0 0 512 512" fill="none" stroke={color} stroke-width="32" stroke-miterlimit="10"><circle cx="220" cy="220" r="150"/><path d="M428 428L338 338"/></svg>
        )}
        {tab.id === 'dictionary' && isActive && (
          <svg class="w-[20px] h-[20px]" viewBox="0 0 512 512" fill={color}><path d="M456.69 421.39L362.6 327.3a173.81 173.81 0 0034.84-104.58C397.44 126.38 319.06 48 222.72 48S48 126.38 48 222.72s78.38 174.72 174.72 174.72A173.81 173.81 0 00327.3 362.6l94.09 94.09a25 25 0 0035.3-35.3zM97.92 222.72a124.8 124.8 0 11124.8 124.8 124.95 124.95 0 01-124.8-124.8z"/></svg>
        )}
        {tab.id === 'progress' && !isActive && (
          <svg class="w-[20px] h-[20px]" viewBox="0 0 512 512" fill="none" stroke={color} stroke-width="32" stroke-linecap="round" stroke-linejoin="round"><path d="M344 280l88-88M232 216l64 64M80 320l104-104"/><circle cx="456" cy="168" r="24" fill="none" stroke={color} stroke-width="32"/><circle cx="320" cy="304" r="24" fill="none" stroke={color} stroke-width="32"/><circle cx="208" cy="192" r="24" fill="none" stroke={color} stroke-width="32"/><circle cx="56" cy="344" r="24" fill="none" stroke={color} stroke-width="32"/></svg>
        )}
        {tab.id === 'progress' && isActive && (
          <svg class="w-[20px] h-[20px]" viewBox="0 0 512 512" fill={color}><path d="M456 144a32 32 0 00-7.24.84l-52.44-52.48A32 32 0 00344 72a32.09 32.09 0 00-31.17 24.88L225.4 128.73A32 32 0 00208 124a32.09 32.09 0 00-31 24.24l-88.37 55.2A32 32 0 0056 196a32 32 0 1025.17 48.75l88.37-55.21a32 32 0 0052.32-15.19l87.37-31.85a32 32 0 0043.53 7.82l52.44 52.48A32 32 0 10456 144z"/></svg>
        )}
        {tab.id === 'ranking' && !isActive && (
          <svg class="w-[20px] h-[20px]" viewBox="0 0 512 512" fill="none" stroke={color} stroke-width="32" stroke-linecap="round" stroke-linejoin="round"><path d="M32 160v296a8 8 0 008 8h136V160a16 16 0 00-16-16H48a16 16 0 00-16 16zM320 48H192a16 16 0 00-16 16v400h160V64a16 16 0 00-16-16zM496 224H384a16 16 0 00-16 16v224h136a8 8 0 008-8V240a16 16 0 00-16-16z"/></svg>
        )}
        {tab.id === 'ranking' && isActive && (
          <svg class="w-[20px] h-[20px]" viewBox="0 0 512 512" fill={color}><path d="M160 32H48a16 16 0 00-16 16v400h144V48a16 16 0 00-16-16zM320 160H208a16 16 0 00-16 16v288h144V176a16 16 0 00-16-16zM480 288H368a16 16 0 00-16 16v160h144V304a16 16 0 00-16-16z"/></svg>
        )}
        {tab.id === 'settings' && !isActive && (
          <svg class="w-[20px] h-[20px]" viewBox="0 0 512 512" fill="none" stroke={color} stroke-width="32" stroke-linecap="round" stroke-linejoin="round"><path d="M262.29 192.31a64 64 0 1057.4 57.4 64.13 64.13 0 00-57.4-57.4zM416.68 264.48l-7.61-7.61a16 16 0 01-4.67-11.37c0-12.19 5-24.71 5-37.5s-5-25.31-5-37.5a16 16 0 014.67-11.37l7.61-7.61a32 32 0 000-45.25l-22.62-22.63a32 32 0 00-45.26 0l-7.61 7.62a16 16 0 01-11.37 4.66c-12.19 0-24.71-5-37.5-5s-25.31 5-37.5 5a16 16 0 01-11.37-4.66l-7.61-7.62a32 32 0 00-45.26 0L168 107.89a32 32 0 000 45.25l7.62 7.61a16 16 0 014.66 11.37c0 12.19-5 24.71-5 37.5s5 25.31 5 37.5a16 16 0 01-4.66 11.37l-7.62 7.61a32 32 0 000 45.26l22.63 22.62a32 32 0 0045.26 0l7.61-7.61a16 16 0 0111.37-4.67c12.19 0 24.71 5 37.5 5s25.31-5 37.5-5a16 16 0 0111.37 4.67l7.61 7.61a32 32 0 0045.26 0l22.62-22.62a32 32 0 000-45.26z"/></svg>
        )}
        {tab.id === 'settings' && isActive && (
          <svg class="w-[20px] h-[20px]" viewBox="0 0 512 512" fill={color}><path d="M256 176a80 80 0 1080 80 80.24 80.24 0 00-80-80zm172.72 80a165.53 165.53 0 01-1.64 22.34l48.69 38.12a11.68 11.68 0 012.8 14.96l-46.06 79.52a11.76 11.76 0 01-14.32 4.72l-57.41-23.08a162.15 162.15 0 01-38.56 22.28l-8.71 60.68a11.71 11.71 0 01-11.52 9.88h-92.12a11.71 11.71 0 01-11.52-9.88l-8.71-60.68a162.15 162.15 0 01-38.56-22.28l-57.41 23.08a11.76 11.76 0 01-14.32-4.72L34.43 331.42a11.68 11.68 0 012.8-14.96l48.69-38.12A165.53 165.53 0 0184.28 256a165.53 165.53 0 011.64-22.34l-48.69-38.12a11.68 11.68 0 01-2.8-14.96l46.06-79.52a11.76 11.76 0 0114.32-4.72l57.41 23.08a162.15 162.15 0 0138.56-22.28l8.71-60.68A11.71 11.71 0 01211.01 27h92.12a11.71 11.71 0 0111.52 9.88l8.71 60.68a162.15 162.15 0 0138.56 22.28l57.41-23.08a11.76 11.76 0 0114.32 4.72l46.06 79.52a11.68 11.68 0 01-2.8 14.96l-48.69 38.12a165.53 165.53 0 011.64 22.34z"/></svg>
        )}
        <span class="text-[8px] font-semibold leading-none" style={`color: ${color}`}>{tab.label}</span>
      </div>
    );
  })}
</div>
