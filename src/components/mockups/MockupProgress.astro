---
import PhoneFrame from './PhoneFrame.astro';
import TabBar from './TabBar.astro';
---

<PhoneFrame>
  <div class="px-4 py-3 text-[#1a1a2e]" style="font-family: 'Inter', sans-serif;">
    <!-- Header -->
    <p class="text-[17px] font-extrabold tracking-tight mb-3">Progreso</p>

    <!-- Stats grid -->
    <div class="grid grid-cols-2 gap-2 mb-3">
      <div class="bg-[#fef3c7] rounded-xl p-2.5">
        <div class="w-8 h-8 rounded-full bg-white/70 flex items-center justify-center mb-1.5">
          <span class="text-[14px]">🔥</span>
        </div>
        <p class="text-[18px] font-extrabold">3</p>
        <p class="text-[9px] font-semibold text-[#92400e]">Días de racha</p>
      </div>
      <div class="bg-[#d1fae5] rounded-xl p-2.5">
        <div class="w-8 h-8 rounded-full bg-white/70 flex items-center justify-center mb-1.5">
          <span class="text-[14px]">⭐</span>
        </div>
        <p class="text-[18px] font-extrabold">450</p>
        <p class="text-[9px] font-semibold text-[#065f46]">XP total</p>
      </div>
      <div class="bg-[#e0e7ff] rounded-xl p-2.5">
        <div class="w-8 h-8 rounded-full bg-white/70 flex items-center justify-center mb-1.5">
          <span class="text-[14px]">📚</span>
        </div>
        <p class="text-[18px] font-extrabold">5</p>
        <p class="text-[9px] font-semibold text-[#3730a3]">Lecciones</p>
      </div>
      <div class="bg-[#fce7f3] rounded-xl p-2.5">
        <div class="w-8 h-8 rounded-full bg-white/70 flex items-center justify-center mb-1.5">
          <span class="text-[14px]">📝</span>
        </div>
        <p class="text-[18px] font-extrabold">87</p>
        <p class="text-[9px] font-semibold text-[#9d174d]">Palabras</p>
      </div>
    </div>

    <!-- Level progress -->
    <div class="bg-white rounded-2xl p-3 mb-3 border border-[#e5e7eb] shadow-sm">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-[14px]">📊</span>
        <p class="text-[12px] font-bold">Nivel actual</p>
      </div>
      <p class="text-[15px] font-extrabold mb-1.5">A0 · Principiante</p>
      <div class="w-full h-2.5 bg-[#e5e7eb] rounded-full overflow-hidden mb-1">
        <div class="h-full bg-[#059669] rounded-full" style="width: 35%"></div>
      </div>
      <p class="text-[9px] text-[#9ca3af]">5 de 14 lecciones completadas</p>
    </div>

    <!-- Achievements -->
    <div class="mb-3">
      <div class="flex items-center justify-between mb-2">
        <div class="flex items-center gap-1.5">
          <span class="text-[14px]">🏆</span>
          <p class="text-[12px] font-bold">Logros</p>
        </div>
        <span class="text-[9px] font-semibold bg-[#d1fae5] text-[#059669] px-2 py-0.5 rounded-full">3 / 12</span>
      </div>

      <div class="grid grid-cols-2 gap-2">
        <!-- Earned -->
        <div class="bg-white rounded-xl p-2.5 border border-[#e5e7eb] shadow-sm relative">
          <div class="w-10 h-10 rounded-full bg-[#d1fae5] flex items-center justify-center mb-1.5 mx-auto">
            <span class="text-[18px]">⭐</span>
          </div>
          <div class="absolute top-2 right-2">
            <svg class="w-3.5 h-3.5 text-[#059669]" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          </div>
          <p class="text-[10px] font-bold text-center">Primera lección</p>
          <p class="text-[8px] text-[#059669] font-semibold text-center mt-0.5">Obtenido</p>
        </div>

        <!-- Earned -->
        <div class="bg-white rounded-xl p-2.5 border border-[#e5e7eb] shadow-sm relative">
          <div class="w-10 h-10 rounded-full bg-[#fef3c7] flex items-center justify-center mb-1.5 mx-auto">
            <span class="text-[18px]">🔥</span>
          </div>
          <div class="absolute top-2 right-2">
            <svg class="w-3.5 h-3.5 text-[#059669]" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          </div>
          <p class="text-[10px] font-bold text-center">3 días seguidos</p>
          <p class="text-[8px] text-[#059669] font-semibold text-center mt-0.5">Obtenido</p>
        </div>

        <!-- Locked -->
        <div class="bg-white rounded-xl p-2.5 border border-[#e5e7eb] shadow-sm opacity-50">
          <div class="w-10 h-10 rounded-full bg-[#f3f4f6] flex items-center justify-center mb-1.5 mx-auto">
            <span class="text-[18px] grayscale">🏅</span>
          </div>
          <p class="text-[10px] font-bold text-center text-[#9ca3af]">Nivel A1</p>
          <p class="text-[8px] text-[#9ca3af] text-center mt-0.5">5 / 14</p>
        </div>

        <!-- Locked -->
        <div class="bg-white rounded-xl p-2.5 border border-[#e5e7eb] shadow-sm opacity-50">
          <div class="w-10 h-10 rounded-full bg-[#f3f4f6] flex items-center justify-center mb-1.5 mx-auto">
            <span class="text-[18px] grayscale">👑</span>
          </div>
          <p class="text-[10px] font-bold text-center text-[#9ca3af]">Racha de 7</p>
          <p class="text-[8px] text-[#9ca3af] text-center mt-0.5">3 / 7</p>
        </div>
      </div>
    </div>

    <TabBar active="progress" />
  </div>
</PhoneFrame>
