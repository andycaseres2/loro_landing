---
import PhoneFrame from './PhoneFrame.astro';
---

<PhoneFrame>
  <div class="flex flex-col h-full text-[#1a1a2e]" style="font-family: 'Inter', sans-serif;">
    <!-- Chat header -->
    <div class="bg-white px-3 py-2.5 border-b border-[#e5e7eb] flex items-center gap-2.5">
      <svg class="w-5 h-5 text-[#059669]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      <img src="/logo.png" alt="" class="w-8 h-8 rounded-full" />
      <div>
        <p class="text-[13px] font-bold">Loro</p>
        <p class="text-[9px] text-[#059669] font-medium">En línea</p>
      </div>
    </div>

    <!-- Messages -->
    <div class="flex-1 px-3 py-3 space-y-3 overflow-hidden bg-[#f0fdf4]">
      <!-- Loro message -->
      <div class="flex items-end gap-2">
        <img src="/logo.png" alt="" class="w-7 h-7 rounded-full" />
        <div class="bg-[#d1fae5] rounded-2xl rounded-bl-sm px-3 py-2 max-w-[80%]">
          <p class="text-[12px] leading-[17px]">¡Hola! 👋 Soy Loro, tu tutor de inglés. Hoy vamos a practicar saludos. Ready?</p>
        </div>
      </div>

      <!-- User message -->
      <div class="flex justify-end">
        <div class="bg-[#059669] rounded-2xl rounded-br-sm px-3 py-2 max-w-[80%]">
          <p class="text-[12px] leading-[17px] text-white">Yes! Hi Loro, how are you?</p>
        </div>
      </div>

      <!-- Loro message with correction -->
      <div class="flex items-end gap-2">
        <img src="/logo.png" alt="" class="w-7 h-7 rounded-full" />
        <div class="bg-[#d1fae5] rounded-2xl rounded-bl-sm px-3 py-2 max-w-[80%]">
          <p class="text-[12px] leading-[17px]">Great! 🎉 "How are you?" es perfecto. Ahora probá responder: <span class="font-bold italic">"I'm fine, thank you"</span></p>
        </div>
      </div>

      <!-- User message -->
      <div class="flex justify-end">
        <div class="bg-[#059669] rounded-2xl rounded-br-sm px-3 py-2 max-w-[80%]">
          <p class="text-[12px] leading-[17px] text-white">I'm fine, tank you</p>
        </div>
      </div>

      <!-- Loro correction -->
      <div class="flex items-end gap-2">
        <img src="/logo.png" alt="" class="w-7 h-7 rounded-full" />
        <div class="bg-[#d1fae5] rounded-2xl rounded-bl-sm px-3 py-2 max-w-[80%]">
          <p class="text-[12px] leading-[17px]">¡Casi! Pequeña corrección: es <span class="font-bold text-[#059669]">"thank"</span> no "tank". La <span class="font-bold">th</span> en inglés se pronuncia con la lengua entre los dientes 😊</p>
        </div>
      </div>

      <!-- User message -->
      <div class="flex justify-end">
        <div class="bg-[#059669] rounded-2xl rounded-br-sm px-3 py-2 max-w-[80%]">
          <p class="text-[12px] leading-[17px] text-white">I'm fine, thank you!</p>
        </div>
      </div>

      <!-- Loro message -->
      <div class="flex items-end gap-2">
        <img src="/logo.png" alt="" class="w-7 h-7 rounded-full" />
        <div class="bg-[#d1fae5] rounded-2xl rounded-bl-sm px-3 py-2 max-w-[80%]">
          <p class="text-[12px] leading-[17px]">Perfect! 🌟 +10 XP. Now let's try something new...</p>
        </div>
      </div>
    </div>

    <!-- Input area -->
    <div class="bg-white border-t border-[#e5e7eb] px-3 py-2.5 flex items-center gap-2 rounded-b-[2rem]">
      <div class="flex-1 bg-[#f8faf9] border border-[#e5e7eb] rounded-full px-3 py-2">
        <p class="text-[11px] text-[#9ca3af]">Escribí tu mensaje...</p>
      </div>
      <div class="w-8 h-8 rounded-full bg-[#059669] flex items-center justify-center">
        <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
      </div>
    </div>
  </div>
</PhoneFrame>
