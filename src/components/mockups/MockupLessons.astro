---
import PhoneFrame from './PhoneFrame.astro';
---

<PhoneFrame>
  <div class="px-4 py-3 text-[#1a1a2e]" style="font-family: 'Inter', sans-serif;">
    <!-- Header -->
    <p class="text-[17px] font-extrabold tracking-tight mb-3">Lecciones</p>

    <!-- Level A0 -->
    <div class="flex items-center gap-1.5 mb-2.5">
      <svg class="w-4 h-4 text-[#059669]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      <p class="text-[14px] font-extrabold">Nivel A0 · Principiante</p>
    </div>

    <!-- Lesson rows -->
    <div class="space-y-2 mb-4">
      <!-- Completed -->
      <div class="bg-white rounded-xl p-2.5 flex items-center gap-2.5 border border-[#e5e7eb] shadow-sm">
        <div class="w-9 h-9 rounded-xl bg-[#d1fae5] flex items-center justify-center">
          <span class="text-[14px]">👋</span>
        </div>
        <div class="flex-1">
          <p class="text-[12px] font-bold">Saludos básicos</p>
          <p class="text-[9px] text-[#9ca3af]">8 ejercicios</p>
        </div>
        <div class="flex items-center gap-1 bg-[#d1fae5] px-2 py-0.5 rounded-full">
          <svg class="w-3 h-3 text-[#059669]" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          <span class="text-[9px] font-bold text-[#059669]">100%</span>
        </div>
      </div>

      <!-- Completed -->
      <div class="bg-white rounded-xl p-2.5 flex items-center gap-2.5 border border-[#e5e7eb] shadow-sm">
        <div class="w-9 h-9 rounded-xl bg-[#d1fae5] flex items-center justify-center">
          <span class="text-[14px]">🔤</span>
        </div>
        <div class="flex-1">
          <p class="text-[12px] font-bold">El abecedario</p>
          <p class="text-[9px] text-[#9ca3af]">12 ejercicios</p>
        </div>
        <div class="flex items-center gap-1 bg-[#d1fae5] px-2 py-0.5 rounded-full">
          <svg class="w-3 h-3 text-[#059669]" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          <span class="text-[9px] font-bold text-[#059669]">100%</span>
        </div>
      </div>

      <!-- Current -->
      <div class="bg-white rounded-xl p-2.5 flex items-center gap-2.5 border-2 border-[#059669] shadow-sm">
        <div class="w-9 h-9 rounded-xl bg-[#d1fae5] flex items-center justify-center">
          <span class="text-[14px]">🏠</span>
        </div>
        <div class="flex-1">
          <p class="text-[12px] font-bold">Presentaciones</p>
          <p class="text-[9px] text-[#9ca3af]">10 ejercicios</p>
        </div>
        <div class="w-7 h-7 rounded-full bg-[#059669] flex items-center justify-center">
          <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        </div>
      </div>

      <!-- Locked -->
      <div class="bg-white rounded-xl p-2.5 flex items-center gap-2.5 border border-[#e5e7eb] shadow-sm opacity-45">
        <div class="w-9 h-9 rounded-xl bg-[#f3f4f6] flex items-center justify-center">
          <span class="text-[14px]">🔢</span>
        </div>
        <div class="flex-1">
          <p class="text-[12px] font-bold">Números 1-20</p>
          <p class="text-[9px] text-[#9ca3af]">10 ejercicios</p>
        </div>
        <svg class="w-4 h-4 text-[#d1d5db]" viewBox="0 0 24 24" fill="currentColor"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
      </div>

      <!-- Locked -->
      <div class="bg-white rounded-xl p-2.5 flex items-center gap-2.5 border border-[#e5e7eb] shadow-sm opacity-45">
        <div class="w-9 h-9 rounded-xl bg-[#f3f4f6] flex items-center justify-center">
          <span class="text-[14px]">🎨</span>
        </div>
        <div class="flex-1">
          <p class="text-[12px] font-bold">Colores</p>
          <p class="text-[9px] text-[#9ca3af]">8 ejercicios</p>
        </div>
        <svg class="w-4 h-4 text-[#d1d5db]" viewBox="0 0 24 24" fill="currentColor"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
      </div>

      <!-- Locked -->
      <div class="bg-white rounded-xl p-2.5 flex items-center gap-2.5 border border-[#e5e7eb] shadow-sm opacity-45">
        <div class="w-9 h-9 rounded-xl bg-[#f3f4f6] flex items-center justify-center">
          <span class="text-[14px]">👨‍👩‍👧</span>
        </div>
        <div class="flex-1">
          <p class="text-[12px] font-bold">La familia</p>
          <p class="text-[9px] text-[#9ca3af]">10 ejercicios</p>
        </div>
        <svg class="w-4 h-4 text-[#d1d5db]" viewBox="0 0 24 24" fill="currentColor"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
      </div>
    </div>

    <!-- Tab bar -->
    <div class="absolute bottom-0 left-0 right-0 bg-white border-t border-[#e5e7eb] flex justify-around py-2 px-2 rounded-b-[2rem]">
      <div class="flex flex-col items-center gap-0.5">
        <svg class="w-5 h-5 text-[#9ca3af]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        <span class="text-[8px] font-semibold text-[#9ca3af]">Hoy</span>
      </div>
      <div class="flex flex-col items-center gap-0.5">
        <svg class="w-5 h-5 text-[#059669]" viewBox="0 0 24 24" fill="currentColor"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
        <span class="text-[8px] font-semibold text-[#059669]">Lecciones</span>
      </div>
      <div class="flex flex-col items-center gap-0.5">
        <svg class="w-5 h-5 text-[#9ca3af]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <span class="text-[8px] font-semibold text-[#9ca3af]">Diccionario</span>
      </div>
      <div class="flex flex-col items-center gap-0.5">
        <svg class="w-5 h-5 text-[#9ca3af]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
        <span class="text-[8px] font-semibold text-[#9ca3af]">Progreso</span>
      </div>
    </div>
  </div>
</PhoneFrame>
