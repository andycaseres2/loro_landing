---
---

<section class="relative pt-36 pb-28 md:pt-40 md:pb-32 overflow-hidden bg-gradient-to-br from-primary via-emerald-500 to-emerald-400">
  <!-- Decorative circles -->
  <div class="absolute -top-1/3 -right-1/5 w-[600px] h-[600px] bg-white/[0.06] rounded-full pointer-events-none"></div>
  <div class="absolute -bottom-1/4 -left-[10%] w-[400px] h-[400px] bg-white/[0.04] rounded-full pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 flex flex-col-reverse md:flex-row items-center gap-10 md:gap-16">
    <!-- Text -->
    <div class="flex-1 text-center md:text-left">
      <div class="inline-flex items-center gap-1.5 bg-white/[0.18] backdrop-blur-sm text-white px-4 py-1.5 rounded-full text-xs font-semibold mb-6">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        App gratuita
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-[1.08] tracking-tight mb-5">
        Aprendé inglés<br />desde cero.<br />Sin excusas.
      </h1>

      <p class="text-lg text-white/90 max-w-md mx-auto md:mx-0 mb-8 leading-relaxed">
        Lecciones interactivas, IA que te corrige, y todo en tu idioma. Pensado para Latinoamérica.
      </p>

      <!-- Store buttons -->
      <div id="download" class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
        <a
          href="#"
          class="inline-flex items-center gap-3 bg-white text-text px-7 py-3.5 rounded-2xl font-semibold text-[0.95rem] hover:-translate-y-0.5 hover:shadow-xl transition-all"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <span class="text-left leading-tight">
            <span class="block text-[0.65rem] font-normal opacity-70">Disponible en</span>
            App Store
          </span>
        </a>
        <a
          href="#"
          class="inline-flex items-center gap-3 bg-white/15 border-2 border-white/30 text-white px-7 py-3.5 rounded-2xl font-semibold text-[0.95rem] hover:-translate-y-0.5 hover:shadow-xl transition-all"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 1.42C2.84 1.79 2.64 2.35 2.64 3.07v17.86c0 .72.2 1.28.54 1.64l.09.09 10.01-10.01v-.22L3.27 1.34l-.09.08z"/><path d="M16.61 15.98l-3.33-3.33v-.22l3.33-3.34.08.04 3.95 2.24c1.13.64 1.13 1.69 0 2.33l-3.95 2.24-.08.04z"/><path d="M16.69 15.94L13.28 12.53 3.18 22.63c.37.39.98.44 1.68.05l11.83-6.74z"/><path d="M16.69 9.06L4.86 2.32c-.7-.39-1.31-.34-1.68.05L13.28 12.47l3.41-3.41z"/></svg>
          <span class="text-left leading-tight">
            <span class="block text-[0.65rem] font-normal opacity-70">Disponible en</span>
            Google Play
          </span>
        </a>
      </div>
    </div>

    <!-- Logo -->
    <div class="shrink-0">
      <div class="w-52 h-52 sm:w-64 sm:h-64 lg:w-80 lg:h-80 bg-white/12 rounded-[2.5rem] flex items-center justify-center backdrop-blur-md animate-float">
        <img
          src="/logo.png"
          alt="Loro - Aprendé inglés"
          width="240"
          height="240"
          class="w-36 sm:w-44 lg:w-60 h-auto drop-shadow-2xl"
        />
      </div>
    </div>
  </div>

  <!-- Wave divider -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block">
      <path d="M0 40C240 80 480 0 720 40C960 80 1200 0 1440 40V80H0V40Z" fill="#f8faf9"/>
    </svg>
  </div>
</section>
