---
---

<section class="py-20 md:py-24 bg-gradient-to-br from-primary to-emerald-500 text-center">
  <div class="max-w-3xl mx-auto px-6 fade-up">
    <!-- Avatars -->
    <div class="flex items-center justify-center -space-x-2.5 mb-4">
      <div class="w-11 h-11 rounded-full border-[3px] border-primary flex items-center justify-center text-white font-bold bg-orange-500">M</div>
      <div class="w-11 h-11 rounded-full border-[3px] border-primary flex items-center justify-center text-white font-bold bg-blue-600">J</div>
      <div class="w-11 h-11 rounded-full border-[3px] border-primary flex items-center justify-center text-white font-bold bg-violet-600">L</div>
      <div class="w-11 h-11 rounded-full border-[3px] border-primary flex items-center justify-center text-white font-bold bg-rose-600">A</div>
      <div class="w-11 h-11 rounded-full border-[3px] border-primary flex items-center justify-center text-white font-bold text-xs bg-primary-dark">+</div>
    </div>

    <!-- Stars -->
    <div class="flex items-center justify-center gap-1 mb-2">
      {[...Array(5)].map(() => (
        <svg class="w-6 h-6 text-yellow-400" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      ))}
    </div>
    <p class="text-sm text-white/70 mb-6">4.9 de 5 estrellas</p>

    <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
      Aprendé inglés o español con la app que te entiende
    </h2>
    <p class="text-base text-white/85 leading-relaxed mb-10 max-w-lg mx-auto">
      Unite a la comunidad de estudiantes que están aprendiendo un nuevo idioma, un día a la vez.
    </p>

    <!-- Stat cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl py-6 px-4 hover:bg-white/20 transition-colors duration-300">
        <div class="text-3xl font-black text-white mb-1">2</div>
        <div class="text-sm text-white/80">Idiomas disponibles</div>
      </div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl py-6 px-4 hover:bg-white/20 transition-colors duration-300">
        <div class="text-3xl font-black text-white mb-1">24+</div>
        <div class="text-sm text-white/80">Lecciones por idioma</div>
      </div>
      <div class="bg-white/15 backdrop-blur-sm rounded-2xl py-6 px-4 hover:bg-white/20 transition-colors duration-300">
        <div class="text-3xl font-black text-white mb-1">1000+</div>
        <div class="text-sm text-white/80">Palabras en cada diccionario</div>
      </div>
    </div>
  </div>
</section>
