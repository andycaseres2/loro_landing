---
const steps = [
  {
    number: 1,
    title: 'Descargá Loro',
    description: 'Disponible en App Store y Google Play. Sin tarjeta de crédito.',
    icon: 'download',
  },
  {
    number: 2,
    title: 'Elegí tu idioma',
    description: '¿Querés aprender inglés o español? Elegí tu camino y tu nivel.',
    icon: 'globe',
  },
  {
    number: 3,
    title: '5 minutos al día',
    description: 'Completá lecciones, chateá con Loro y mirá cómo progresás.',
    icon: 'bolt',
  },
];
---

<section id="how-it-works" class="py-24 md:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center max-w-xl mx-auto mb-16 fade-up">
      <span class="inline-block text-xs font-bold uppercase tracking-widest text-primary mb-3">
        Cómo funciona
      </span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-text tracking-tight leading-tight mb-4">
        Empezá en 3 simples pasos
      </h2>
      <p class="text-text-secondary text-base leading-relaxed">
        En menos de un minuto ya estás aprendiendo.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-10 stagger-children">
      <!-- Connecting line (desktop only) -->
      <div class="hidden md:block absolute top-11 left-[15%] right-[15%] h-0.5 bg-gradient-to-r from-primary-light via-primary to-primary-light"></div>

      {steps.map((step) => (
        <div class="text-center relative fade-up group">
          <div class="w-[88px] h-[88px] rounded-full bg-gradient-to-br from-primary to-emerald-500 text-white flex flex-col items-center justify-center mx-auto mb-6 relative z-10 shadow-[0_8px_25px_rgba(5,150,105,0.25)] group-hover:scale-110 transition-transform duration-300">
            {step.icon === 'download' && (
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
            )}
            {step.icon === 'globe' && (
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            )}
            {step.icon === 'bolt' && (
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            )}
          </div>
          <h3 class="text-lg font-bold text-text mb-2">{step.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed max-w-[260px] mx-auto">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
