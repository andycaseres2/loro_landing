---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;

const steps = [
  {
    number: 1,
    title: t(lang, 'howItWorks.0.title'),
    description: t(lang, 'howItWorks.0.description'),
    icon: 'download',
    color: 'from-primary to-emerald-500',
    shadow: 'rgba(5,150,105,0.3)',
    bg: 'bg-primary-light',
  },
  {
    number: 2,
    title: t(lang, 'howItWorks.1.title'),
    description: t(lang, 'howItWorks.1.description'),
    icon: 'globe',
    color: 'from-accent to-amber-500',
    shadow: 'rgba(249,115,22,0.3)',
    bg: 'bg-accent-light',
  },
  {
    number: 3,
    title: t(lang, 'howItWorks.2.title'),
    description: t(lang, 'howItWorks.2.description'),
    icon: 'bolt',
    color: 'from-violet-500 to-indigo-500',
    shadow: 'rgba(139,92,246,0.3)',
    bg: 'bg-violet-50',
  },
];
---

<section id="how-it-works" class="py-24 md:py-28 bg-surface">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center max-w-xl mx-auto mb-16 fade-up">
      <span class="inline-block text-xs font-bold uppercase tracking-widest text-primary mb-3">
        {t(lang, 'howItWorks.label')}
      </span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-text tracking-tight leading-tight mb-4">
        {t(lang, 'howItWorks.title')}
      </h2>
      <p class="text-text-secondary text-base leading-relaxed">
        {t(lang, 'howItWorks.subtitle')}
      </p>
    </div>

    <!-- Steps -->
    <div class="relative grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6 stagger-children">
      <!-- Connecting line (desktop only) -->
      <div class="hidden md:block absolute top-[52px] left-[20%] right-[20%] h-[2px]">
        <div class="w-full h-full bg-gradient-to-r from-primary via-accent to-violet-500 rounded-full opacity-30"></div>
        <!-- Animated dots on line -->
        <div class="absolute top-1/2 left-[25%] -translate-y-1/2 w-2 h-2 rounded-full bg-primary"></div>
        <div class="absolute top-1/2 left-[50%] -translate-y-1/2 w-2 h-2 rounded-full bg-accent"></div>
        <div class="absolute top-1/2 left-[75%] -translate-y-1/2 w-2 h-2 rounded-full bg-violet-500"></div>
      </div>

      {steps.map((step) => (
        <div class="relative fade-up group">
          <div class="bg-card rounded-2xl border border-border p-8 text-center hover:shadow-xl hover:border-transparent hover:-translate-y-1 transition-all duration-300">
            <!-- Step number badge -->
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class={`inline-flex items-center justify-center w-7 h-7 rounded-full bg-gradient-to-br ${step.color} text-white text-xs font-bold shadow-lg`}>
                {step.number}
              </span>
            </div>

            <!-- Icon -->
            <div
              class={`w-[80px] h-[80px] rounded-2xl bg-gradient-to-br ${step.color} text-white flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform duration-300`}
              style={`box-shadow: 0 10px 30px ${step.shadow}`}
            >
              {step.icon === 'download' && (
                <svg class="w-9 h-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              )}
              {step.icon === 'globe' && (
                <svg class="w-9 h-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              )}
              {step.icon === 'bolt' && (
                <svg class="w-9 h-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              )}
            </div>

            <h3 class="text-lg font-bold text-text mb-2">{step.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
