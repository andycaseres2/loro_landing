---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;

const testimonials = [
  {
    name: 'María González',
    location: 'Buenos Aires, Argentina',
    avatar: '/testimonials/maria.jpg',
    initials: 'MG',
    color: 'bg-rose-500',
    text: 'Probé muchas apps y ninguna me explicaba en español. Con Loro por fin entiendo los errores que cometo. Llevo 45 días de racha.',
    rating: 5,
    learning: 'Aprendiendo inglés',
  },
  {
    name: 'James Carter',
    location: 'Austin, Texas',
    avatar: '/testimonials/james.jpg',
    initials: 'JC',
    color: 'bg-blue-600',
    text: "I tried Duolingo for Spanish but it felt robotic. Loro's AI chat is like talking to a real tutor. My Spanish improved more in 2 weeks than in months before.",
    rating: 5,
    learning: 'Learning Spanish',
  },
  {
    name: 'Lucía Ramírez',
    location: 'Bogotá, Colombia',
    avatar: '/testimonials/lucia.jpg',
    initials: 'LR',
    color: 'bg-violet-600',
    text: 'Lo que más me gusta es que puedo practicar offline en el metro. Las lecciones son cortitas y la gamificación me tiene enganchada.',
    rating: 5,
    learning: 'Aprendiendo inglés',
  },
];
---

<section class="py-24 md:py-28 bg-bg">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center max-w-xl mx-auto mb-16 fade-up">
      <span class="inline-block text-xs font-bold uppercase tracking-widest text-primary mb-3">
        {t(lang, 'testimonials.label')}
      </span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-text tracking-tight leading-tight mb-4">
        {t(lang, 'testimonials.title')}
      </h2>
      <p class="text-text-secondary text-base leading-relaxed">
        {t(lang, 'testimonials.subtitle')}
      </p>
    </div>

    <!-- Testimonial cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">
      {testimonials.map((tm) => (
        <div class="bg-card rounded-2xl p-8 border border-border hover:shadow-xl hover:border-primary/20 transition-all duration-300 fade-up flex flex-col">
          <!-- Stars -->
          <div class="flex items-center gap-0.5 mb-4">
            {[...Array(tm.rating)].map(() => (
              <svg class="w-5 h-5 text-yellow-400" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-text-secondary text-sm leading-relaxed mb-6 flex-1">
            "{tm.text}"
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <!-- PLACEHOLDER: Reemplazar con foto real del usuario -->
            <div class={`w-11 h-11 rounded-full flex items-center justify-center text-white font-bold text-sm ${tm.color}`}>
              {tm.initials}
            </div>
            <div>
              <p class="text-sm font-bold text-text">{tm.name}</p>
              <p class="text-xs text-text-muted">{tm.location}</p>
            </div>
          </div>

          <!-- Language badge -->
          <div class="mt-4 pt-4 border-t border-border">
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-primary bg-primary-light px-3 py-1 rounded-full">
              {tm.learning.includes('inglés') ? '🇺🇸' : '🇪🇸'}
              {tm.learning}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
