---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;

const faqs = Array.from({ length: 6 }, (_, i) => ({
  question: t(lang, `faq.${i}.question`),
  answer: t(lang, `faq.${i}.answer`),
}));
---

<section id="faq" class="py-24 md:py-28 bg-surface">
  <div class="max-w-3xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center max-w-xl mx-auto mb-16 fade-up">
      <span class="inline-block text-xs font-bold uppercase tracking-widest text-primary mb-3">
        {t(lang, 'faq.label')}
      </span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-text tracking-tight leading-tight mb-4">
        {t(lang, 'faq.title')}
      </h2>
      <p class="text-text-secondary text-base leading-relaxed">
        {t(lang, 'faq.subtitle')}
      </p>
    </div>

    <!-- FAQ Items -->
    <div class="space-y-3 fade-up">
      {faqs.map((faq, i) => (
        <div class="bg-bg rounded-2xl border border-border overflow-hidden faq-item" data-faq={i}>
          <button
            class="w-full flex items-center justify-between px-6 py-5 text-left hover:bg-primary-light/30 transition-colors duration-200"
            data-faq-toggle={i}
          >
            <span class="text-base font-semibold text-text pr-4">{faq.question}</span>
            <svg class="w-5 h-5 text-text-muted shrink-0 faq-chevron" data-faq-chevron={i} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>
          <div class="faq-answer" data-faq-answer={i}>
            <div>
              <p class="px-6 pb-5 text-sm text-text-secondary leading-relaxed">
                {faq.answer}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-faq-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const i = btn.getAttribute('data-faq-toggle');
      const answer = document.querySelector(`[data-faq-answer="${i}"]`);
      const chevron = document.querySelector(`[data-faq-chevron="${i}"]`);

      // Close all others
      document.querySelectorAll('.faq-answer.open').forEach((el) => {
        if (el !== answer) {
          el.classList.remove('open');
          const otherI = el.getAttribute('data-faq-answer');
          document.querySelector(`[data-faq-chevron="${otherI}"]`)?.classList.remove('open');
        }
      });

      // Toggle current
      answer?.classList.toggle('open');
      chevron?.classList.toggle('open');
    });
  });
</script>
