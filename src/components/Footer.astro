---
---

<footer class="bg-[#1a1a2e] dark:bg-[#080f1a] pt-12 pb-8">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Brand -->
      <div class="flex items-center gap-2.5">
        <img src="/logo-dark.png" alt="Loro" width="32" height="32" class="rounded-xl" />
        <span class="font-bold text-lg text-slate-100">Loro</span>
      </div>

      <!-- Links -->
      <ul class="flex flex-wrap justify-center gap-7 list-none">
        <li><a href="/" class="text-sm text-slate-400 hover:text-slate-100 transition-colors">Inicio</a></li>
        <li><a href="/#features" class="text-sm text-slate-400 hover:text-slate-100 transition-colors">Funciones</a></li>
        <li><a href="/privacy" class="text-sm text-slate-400 hover:text-slate-100 transition-colors">Privacidad</a></li>
        <li><a href="/terms" class="text-sm text-slate-400 hover:text-slate-100 transition-colors">Términos</a></li>
        <li><a href="mailto:contacto@loro.app" class="text-sm text-slate-400 hover:text-slate-100 transition-colors">Contacto</a></li>
      </ul>

      <!-- Social -->
      <div class="flex gap-3">
        <a
          href="#"
          aria-label="Instagram"
          class="w-10 h-10 rounded-xl bg-white/8 flex items-center justify-center text-slate-400 hover:bg-primary hover:text-white transition-all"
        >
          <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </a>
        <a
          href="#"
          aria-label="X (Twitter)"
          class="w-10 h-10 rounded-xl bg-white/8 flex items-center justify-center text-slate-400 hover:bg-primary hover:text-white transition-all"
        >
          <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16h-4.267z"/><path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"/></svg>
        </a>
        <a
          href="#"
          aria-label="TikTok"
          class="w-10 h-10 rounded-xl bg-white/8 flex items-center justify-center text-slate-400 hover:bg-primary hover:text-white transition-all"
        >
          <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
        </a>
      </div>
    </div>

    <!-- Bottom -->
    <div class="text-center mt-8 pt-6 border-t border-white/8 text-slate-500 text-xs">
      &copy; 2026 Loro. Todos los derechos reservados.
    </div>
  </div>
</footer>
