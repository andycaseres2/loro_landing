---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;

const screens = [
  {
    title: t(lang, 'screenshots.0.title'),
    description: t(lang, 'screenshots.0.description'),
    image: '/screenshots/chat-real.png',
  },
  {
    title: t(lang, 'screenshots.1.title'),
    description: t(lang, 'screenshots.1.description'),
    image: '/screenshots/lessons.png',
  },
  {
    title: t(lang, 'screenshots.2.title'),
    description: t(lang, 'screenshots.2.description'),
    image: '/screenshots/progress.png',
  },
];
---

<section id="preview" class="py-24 md:py-28 bg-surface overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center max-w-xl mx-auto mb-16 fade-up">
      <span class="inline-block text-xs font-bold uppercase tracking-widest text-accent mb-3">
        {t(lang, 'screenshots.label')}
      </span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-text tracking-tight leading-tight mb-4">
        {t(lang, 'screenshots.title')} <span class="gradient-text">{t(lang, 'screenshots.titleHighlight')}</span>
      </h2>
      <p class="text-text-secondary text-base leading-relaxed">
        {t(lang, 'screenshots.subtitle')}
      </p>
    </div>

    <!-- Screenshots -->
    <div class="flex flex-col md:flex-row items-start justify-center gap-10 md:gap-6 lg:gap-10">
      {screens.map((screen, i) => (
        <div class={`flex flex-col items-center fade-up mx-auto md:mx-0 ${i === 1 ? 'md:-mt-8' : ''}`}>
          <div class="hover:-translate-y-2 transition-transform duration-500">
            <img
              src={screen.image}
              alt={`Loro App - ${screen.title}`}
              class="w-[260px] h-auto rounded-[2.5rem] shadow-2xl shadow-black/20"
            />
          </div>
          <div class="text-center mt-5">
            <h3 class="text-base font-bold text-text">{screen.title}</h3>
            <p class="text-sm text-text-secondary mt-1">{screen.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
