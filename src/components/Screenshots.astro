---
const screens = [
  {
    title: 'Chat con IA',
    description: 'Conversaciones reales con correcciones instantáneas',
    image: '/screenshots/chat.png',
  },
  {
    title: 'Lecciones interactivas',
    description: 'Ejercicios variados que se adaptan a tu nivel',
    image: '/screenshots/lecciones.png',
  },
  {
    title: 'Tu progreso',
    description: 'Estadísticas, rachas y logros que te motivan',
    image: '/screenshots/progreso.png',
  },
];
---

<section id="preview" class="py-24 md:py-28 bg-white overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center max-w-xl mx-auto mb-16 fade-up">
      <span class="inline-block text-xs font-bold uppercase tracking-widest text-accent mb-3">
        Así se ve
      </span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-text tracking-tight leading-tight mb-4">
        Una app diseñada para que <span class="gradient-text">disfrutes aprender</span>
      </h2>
      <p class="text-text-secondary text-base leading-relaxed">
        Interfaz limpia, intuitiva y con todo lo que necesitás al alcance de un tap.
      </p>
    </div>

    <!-- Screenshots -->
    <div class="flex flex-col md:flex-row items-center justify-center gap-8 md:gap-6 lg:gap-10">
      {screens.map((screen, i) => (
        <div class={`flex flex-col items-center ${i === 1 ? 'md:-mt-8' : ''} fade-up`}>
          <img
            src={screen.image}
            alt={`Loro App - ${screen.title}`}
            class="w-[220px] sm:w-[240px] h-auto rounded-3xl shadow-2xl shadow-black/20 hover:-translate-y-2 transition-transform duration-500"
          />
          <!-- Caption -->
          <div class="text-center mt-5">
            <h3 class="text-base font-bold text-text">{screen.title}</h3>
            <p class="text-sm text-text-secondary mt-1">{screen.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
