---
import MockupChat from './mockups/MockupChat.astro';
---

<section id="preview" class="py-24 md:py-28 bg-white overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center max-w-xl mx-auto mb-16 fade-up">
      <span class="inline-block text-xs font-bold uppercase tracking-widest text-accent mb-3">
        Así se ve
      </span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-text tracking-tight leading-tight mb-4">
        Una app diseñada para que <span class="gradient-text">disfrutes aprender</span>
      </h2>
      <p class="text-text-secondary text-base leading-relaxed">
        Interfaz limpia, intuitiva y con todo lo que necesitás al alcance de un tap.
      </p>
    </div>

    <!-- Screenshots -->
    <div class="flex flex-col md:flex-row items-start justify-center gap-10 md:gap-6 lg:gap-10">
      <!-- Chat (CSS mockup - real screenshot is too empty) -->
      <div class="flex flex-col items-center fade-up mx-auto md:mx-0">
        <div class="hover:-translate-y-2 transition-transform duration-500">
          <MockupChat />
        </div>
        <div class="text-center mt-5">
          <h3 class="text-base font-bold text-text">Chat con IA</h3>
          <p class="text-sm text-text-secondary mt-1">Conversaciones reales con correcciones</p>
        </div>
      </div>

      <!-- Lessons (real screenshot) -->
      <div class="flex flex-col items-center fade-up md:-mt-8 mx-auto md:mx-0">
        <div class="hover:-translate-y-2 transition-transform duration-500">
          <img
            src="/screenshots/lessons.png"
            alt="Loro App - Lecciones"
            class="w-[260px] h-auto rounded-[2.5rem] shadow-2xl shadow-black/20"
          />
        </div>
        <div class="text-center mt-5">
          <h3 class="text-base font-bold text-text">Lecciones interactivas</h3>
          <p class="text-sm text-text-secondary mt-1">Ejercicios que se adaptan a tu nivel</p>
        </div>
      </div>

      <!-- Progress (real screenshot) -->
      <div class="flex flex-col items-center fade-up mx-auto md:mx-0">
        <div class="hover:-translate-y-2 transition-transform duration-500">
          <img
            src="/screenshots/progress.png"
            alt="Loro App - Progreso"
            class="w-[260px] h-auto rounded-[2.5rem] shadow-2xl shadow-black/20"
          />
        </div>
        <div class="text-center mt-5">
          <h3 class="text-base font-bold text-text">Tu progreso</h3>
          <p class="text-sm text-text-secondary mt-1">Estadísticas, rachas y logros</p>
        </div>
      </div>
    </div>
  </div>
</section>
