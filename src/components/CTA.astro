---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
---

<section class="py-24 md:py-28 bg-bg text-center">
  <div class="max-w-2xl mx-auto px-6 fade-up">
    <div class="inline-flex items-center gap-2 bg-accent/10 text-accent px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-6">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      {t(lang, 'cta.badge')}
    </div>

    <h2 class="text-3xl md:text-4xl font-extrabold text-text tracking-tight leading-tight mb-4">
      {t(lang, 'cta.title')}
    </h2>
    <p class="text-lg text-text-secondary max-w-md mx-auto mb-4 leading-relaxed">
      {t(lang, 'cta.subtitle')}
    </p>
    <p class="text-sm text-text-muted mb-8">
      {t(lang, 'cta.availability')}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#"
        class="inline-flex items-center justify-center gap-3 bg-primary text-white px-8 py-4 rounded-2xl font-semibold text-base hover:-translate-y-0.5 hover:shadow-xl hover:bg-primary-dark transition-all pulse-glow"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        <span class="text-left leading-tight">
          <span class="block text-[0.65rem] font-normal opacity-70">{t(lang, 'hero.availableOn')}</span>
          App Store
        </span>
      </a>
      <a
        href="#"
        class="inline-flex items-center justify-center gap-3 bg-[#1a1a2e] dark:bg-[#1e293b] text-white px-8 py-4 rounded-2xl font-semibold text-base hover:-translate-y-0.5 hover:shadow-xl transition-all pulse-glow"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 1.42C2.84 1.79 2.64 2.35 2.64 3.07v17.86c0 .72.2 1.28.54 1.64l.09.09 10.01-10.01v-.22L3.27 1.34l-.09.08z"/><path d="M16.61 15.98l-3.33-3.33v-.22l3.33-3.34.08.04 3.95 2.24c1.13.64 1.13 1.69 0 2.33l-3.95 2.24-.08.04z"/><path d="M16.69 15.94L13.28 12.53 3.18 22.63c.37.39.98.44 1.68.05l11.83-6.74z"/><path d="M16.69 9.06L4.86 2.32c-.7-.39-1.31-.34-1.68.05L13.28 12.47l3.41-3.41z"/></svg>
        <span class="text-left leading-tight">
          <span class="block text-[0.65rem] font-normal opacity-70">{t(lang, 'hero.availableOn')}</span>
          Google Play
        </span>
      </a>
    </div>
  </div>
</section>
